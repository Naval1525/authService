# Server
PORT=8080
NODE_ENV=development
APP_URL=http://localhost:8080

# Database
# Local dev (app on host): use localhost.
# Docker Compose overrides this to the "postgres" service host automatically.
DATABASE_URL=postgresql://postgres:password@localhost:5432/authdb

# Redis
# Docker Compose overrides this to the "redis" service host automatically.
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me

# Mail (optional — if SMTP_HOST is unset, emails are logged to console instead of sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Auth Service <no-reply@auth-service.local>"

# Docker Compose only (optional overrides; defaults shown)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=authdb
