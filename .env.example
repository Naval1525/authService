# Server
PORT=8080
NODE_ENV=development
APP_URL=http://localhost:8080

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/auth_service

# Auth
JWT_SECRET=change-me

# Mail (optional — if SMTP_HOST is unset, emails are logged to console instead of sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Auth Service <no-reply@auth-service.local>"
